# ==========================================
# PolyBot - Variables de Entorno
# ==========================================

# Flask
FLASK_SECRET_KEY=cambia-esto-por-una-clave-segura-aleatoria
FLASK_DEBUG=false

# Server
HOST=0.0.0.0
PORT=5000

# Encriptación (opcional, se genera automáticamente si no se define)
# POLYBOT_ENCRYPTION_KEY=tu-clave-fernet-base64

# Polymarket API (también configurable desde el dashboard)
# POLY_API_KEY=tu-api-key
# POLY_API_SECRET=tu-api-secret
# POLY_PASSPHRASE=tu-passphrase

# Telegram (también configurable desde el dashboard)
# TELEGRAM_TOKEN=tu-token-de-bot
# TELEGRAM_CHAT_ID=tu-chat-id
